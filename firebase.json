{
  "hosting": {
    "public": "build/web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**",
        "headers": [
          {
            "key": "Cross-Origin-Opener-Policy",
            "value": "same-origin-allow-popups"
          },
          {
            "key": "Cache-Control",
            "value": "no-cache, no-store, must-revalidate"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/termos.html",
        "destination": "/termos.html"
      },
      {
        "source": "/privacidade.html",
        "destination": "/privacidade.html"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
